  "keyFeatures": [
    "Statically-typed programming language for zero-knowledge applications",
    "Compiles to Aleo bytecode for formally verified ZK proofs",
    "Built-in support for records, mappings, and on-chain storage",
    "Comprehensive CLI with project scaffolding, testing, and deployment",
    "Integration with Aleo blockchain for decentralized applications",
    "Type system with integers, addresses, fields, groups, and custom types",
    "Public and private function execution modes",
    "Package manager for importing dependencies"
  ],
  "publicApiSurface": [
    "leo new - Create a new Leo project",
    "leo build - Compile a Leo program",
    "leo run - Execute a program locally",
    "leo execute - Execute a program on-chain",
    "leo test - Run program tests",
    "leo deploy - Deploy a program to the network",
    "leo devnet - Run a local devnet",
    "leo devnode - Run a local devnode",
    "leo query - Query data from the Aleo network",
    "leo account - Manage Aleo accounts",
    "leo add - Add a dependency",
    "leo remove - Remove a dependency",
    "leo clean - Clean build artifacts",
    "leo update - Update Leo CLI",
    "leo fmt - Format Leo source files"
  ]
